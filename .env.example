# Copy to .env.local and fill in. .env*.local is gitignored, so the key stays out of the repo.

# PostHog product analytics (cookieless, no consent banner; PO Lock 6, 2026-06-03).
# Get the project API key from PostHog: Project settings -> Project API Key (starts with "phc_").
# Leave NEXT_PUBLIC_POSTHOG_KEY unset to disable analytics entirely (the provider no-ops).
NEXT_PUBLIC_POSTHOG_KEY=
# US cloud is the chosen region (Lock 6a). For EU cloud use https://eu.i.posthog.com.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
